FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant/fins";
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heSolidThermo;
    mixture         pureMixture;
    transport       constIso;
    thermo          hConst;
    equationOfState rhoConst;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight       26.98;
    }
    transport
    {
        kappa           167;        // Aluminium 6061  [W/m/K]
    }
    thermodynamics
    {
        Hf              0;
        Cp              900;        // [J/kg/K]
    }
    equationOfState
    {
        rho             2700;       // [kg/m^3]
    }
}

