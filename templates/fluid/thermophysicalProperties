FoamFile
{
    version     2.0;
    format      ascii;
    class       dictionary;
    location    "constant/fluid";
    object      physicalProperties;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

thermoType
{
    type            heRhoThermo;
    mixture         pureMixture;
    transport       const;
    thermo          hConst;
    equationOfState perfectGas;
    specie          specie;
    energy          sensibleEnthalpy;
}

mixture
{
    specie
    {
        molWeight       28.96;      // dry air
    }
    thermodynamics
    {
        Cp              1005;       // [J/kg/K]
        Hf              0;
    }
    transport
    {
        mu              1.84e-05;   // [Pa.s] @ ~300 K
        Pr              0.705;
    }
}

